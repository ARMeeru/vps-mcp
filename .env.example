# SSH Key Passphrases (if needed)
SSH_KEY_PASS=your_ssh_key_passphrase_here
STAGING_SSH_KEY_PASS=your_staging_key_passphrase

# Server Configuration
SERVERS_CONFIG_PATH=./config/servers.yaml

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs
AUDIT_LOG_ENABLED=true

# Connection Pool Settings
MAX_CONNECTIONS_PER_SERVER=3
HEALTH_CHECK_INTERVAL=30
CONNECTION_RETRY_MAX_DELAY=30

# Security Settings
MAX_COMMAND_LENGTH=10000
MAX_FILE_SIZE_MB=50
COMMAND_TIMEOUT_DEFAULT=30
