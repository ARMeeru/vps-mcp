# Include documentation and configuration files
include README.md
include INSTALL.md
include LICENSE
include requirements.txt
include pyproject.toml
include *.py

# Include configuration templates
include config/*.yaml
include templates/*.yaml
include templates/*.json

# Include scripts
include bin/mcp-vps-manager

# Include source code
recursive-include src *.py
recursive-include src *.yaml
recursive-include src *.json

# Exclude development and temporary files
exclude *.pyc
exclude .env
exclude .env.*
exclude simple_start.sh
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude .git*
global-exclude *.log
